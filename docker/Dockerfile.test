# Parameterized Dockerfile for trtutils CUDA test containers.
# Used by docker-compose.test.yml with build args per CUDA version.
#
# Args:
#   BASE_IMAGE     – NVIDIA CUDA base image (e.g. nvidia/cuda:12.6.0-cudnn-devel-ubuntu22.04)
#   CUDA_VERSION   – Major CUDA version used to select the pip extras group (11, 12, or 13)
#   PIP_EXTRA_FLAGS – Extra flags for pip install (e.g. --break-system-packages for Ubuntu 24.04)

ARG BASE_IMAGE
FROM ${BASE_IMAGE}

ENV DEBIAN_FRONTEND=noninteractive

ARG PIP_EXTRA_FLAGS=""
ARG CUDA_VERSION

RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 python3-pip python3-dev \
        libgl1-mesa-glx libglib2.0-0 libsm6 libxext6 libxrender-dev git \
    && rm -rf /var/lib/apt/lists/*

RUN python3 -m pip install ${PIP_EXTRA_FLAGS} --upgrade pip setuptools wheel

WORKDIR /workspace/trtutils

COPY pyproject.toml README.md ./
COPY src/ src/

RUN python3 -m pip install ${PIP_EXTRA_FLAGS} --no-cache-dir ".[cu${CUDA_VERSION},test,ci]"

COPY tests/ tests/
COPY data/ data/
COPY ci/ ci/
COPY demos/ demos/
COPY examples/ examples/
